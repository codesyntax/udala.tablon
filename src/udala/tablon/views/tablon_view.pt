<html xmlns="http://www.w3.org/1999/xhtml"
      xmlns:i18n="http://xml.zope.org/namespaces/i18n"
      xmlns:metal="http://xml.zope.org/namespaces/metal"
      xmlns:tal="http://xml.zope.org/namespaces/tal"
      metal:use-macro="context/main_template/macros/master"
      i18n:domain="udala.tablon"
>

  <body>

    <metal:custom_title fill-slot="content-title">
      <h1 class="documentFirstHeading mb-4" tal:replace="structure context/@@title"></h1>
    </metal:custom_title>

    <metal:custom_description fill-slot="content-description">
      <div class="documentDescription lead text-secondary mb-4 pb-3 border-bottom" tal:replace="structure context/@@description"></div>
    </metal:custom_description>

    <metal:content-core fill-slot="content-core">
      <metal:block define-macro="content-core">

        <div id="parent-fieldname-text"
             tal:define="
               toc context/table_of_contents|nothing;
             "
             tal:condition="context/text"
             tal:content="structure python:context.text.output_relative_to(view.context)"
             tal:attributes="
               class python: toc and 'pat-autotoc' or '';
             "
        >
        </div>

        <tal:content define="
                       Batch python:modules['Products.CMFPlone'].Batch;
                       b_size python:int(request.get('b_size', 20));
                       b_start python:int(request.get('b_start', 0));
                       results python:context.restrictedTraverse('@@folderListing')(sort_on='effective', sort_order='reverse', batch=True, b_size=b_size, b_start=b_start);
                       batch python:Batch(results, b_size, b_start);
                       icons python:context.restrictedTraverse('@@iconresolver');
                     ">
          
          <div class="card shadow-sm border-0 mb-4"
               tal:condition="batch"
          >
            <div class="table-responsive m-0">

              <table class="table table-hover table-striped mb-0 align-middle"
                     tal:define="
                       toLocalizedTime nocall:here/@@plone/toLocalizedTime;
                     "
              >
                <thead class="table-light text-secondary">
                  <tr>
                    <th i18n:translate="" class="fw-semibold border-bottom-0 py-3 ps-4">Document number</th>
                    <th i18n:translate="" class="fw-semibold border-bottom-0 py-3">Description</th>
                    <th i18n:translate="" class="fw-semibold border-bottom-0 py-3">Origin</th>
                    <th i18n:translate="" class="fw-semibold border-bottom-0 py-3">Publication date</th>
                    <th i18n:translate="" class="fw-semibold border-bottom-0 py-3 pe-4">Expiration date</th>
                  </tr>
                </thead>
                <tbody class="border-top-0">
                  <tr tal:repeat="item batch">
                    <tal:obj define="
                               obj python:item.getObject();
                             ">
                      <td class="ps-4 fw-medium text-dark">
                        <a class="text-decoration-none fw-bold"
                           tal:content="item/Title"
                           tal:attributes="
                             href item/getURL;
                           "
                        >
                          Titlt</a>
                      </td>
                      <td class="text-secondary">
                        <span tal:replace="obj/Description"></span>
                      </td>
                      <td class="text-secondary">
                        <span tal:replace="obj/origin_department"></span>
                      </td>
                      <td class="text-secondary">
                        <span class="badge bg-light text-dark border shadow-sm px-2 py-1 fw-normal">
                          <span class="me-1 text-primary d-inline-flex align-items-center" tal:content="structure python:icons.tag('calendar')"></span>
                          <span tal:replace="python:toLocalizedTime(obj.effective_date)"></span>
                        </span>
                      </td>
                      <td class="pe-4 text-secondary">
                        <span class="badge bg-light text-dark border shadow-sm px-2 py-1 fw-normal">
                          <span class="me-1 text-primary d-inline-flex align-items-center" tal:content="structure python:icons.tag('calendar-x')"></span>
                          <span tal:replace="python:toLocalizedTime(obj.expiration_date)"></span>
                        </span>
                      </td>
                    </tal:obj>
                  </tr>
                </tbody>
              </table>

            </div>
          </div>
          
          <div class="alert alert-info d-flex align-items-center shadow-sm my-4"
               tal:condition="not:batch"
          >
             <span class="fs-4 me-3 d-flex align-items-center text-info" tal:content="structure python:icons.tag('info-circle')"></span>
             <p class="mb-0" i18n:translate="">There is no data</p>
          </div>

          <div metal:use-macro="context/batch_macros/macros/navigation"></div>
        </tal:content>

        <div id="parent-fieldname-sponsors-text"
             tal:define="
               toc context/table_of_contents|nothing;
             "
             tal:condition="context/sponsors"
             tal:content="structure python:context.sponsors.output_relative_to(view.context)"
             tal:attributes="
               class python: toc and 'pat-autotoc' or '';
             "
        >
        </div>

      </metal:block>
    </metal:content-core>
  </body>

</html>
